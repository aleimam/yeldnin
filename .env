# ── YeldnIN environment (placeholder values; real secrets go in .env.local) ──

# Prisma CLI uses this to locate the SQLite file (relative to the prisma/ dir).
DATABASE_URL="file:./dev.db"

# Internal HTTP port (behind nginx in production). Matches package.json scripts.
PORT=3200

# Session cookie HMAC secret. OVERRIDE in .env.local with a long random string.
SESSION_SECRET="dev-only-change-me-in-env-local"

# Default locale ("en" or "ar")
DEFAULT_LOCALE="en"

# ── Web push (VAPID) ──────────────────────────────────────────────────────────
# The PUBLIC key is safe to commit (the browser needs it to subscribe). The
# PRIVATE key is a secret — set it in .env.local (dev) and the prod environment.
# Regenerate a pair with:  node -e "console.log(require('web-push').generateVAPIDKeys())"
VAPID_PUBLIC_KEY="BHEOESEQclK3m67XcGKwWX11yQh3mKLtQ0veocW6RxfK2pHNZF3nOkVDD5SNpH-eWRNNHjeEYF8ZMhvGEWIw2ak"
VAPID_PRIVATE_KEY=""
VAPID_SUBJECT="mailto:admin@yeldn.local"
