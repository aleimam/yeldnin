# ── YeldnIN environment template ──
# Copy to .env.local on the server and fill real values. .env.local is gitignored
# and is loaded by Next.js at build & runtime (overrides .env).

# Prisma CLI uses this to locate the SQLite file (relative to the prisma/ dir).
DATABASE_URL="file:./dev.db"

# Internal HTTP port (nginx proxies in.yeldn.com -> 127.0.0.1:PORT).
PORT=3200

# Session cookie HMAC secret. REQUIRED in production — generate a long random
# value, e.g.:  node -e "console.log(require('crypto').randomBytes(48).toString('base64url'))"
SESSION_SECRET="CHANGE-ME-LONG-RANDOM-STRING"

# Default locale ("en" or "ar")
DEFAULT_LOCALE="en"
