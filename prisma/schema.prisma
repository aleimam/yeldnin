// YeldnIN — Prisma schema (SQLite)
// Phase 0/1 foundation: auth, RBAC (roles/permissions/teams), modules, settings.
// Module-specific models (Pricing, etc.) are added in their own phases.

generator client {
  provider   = "prisma-client-js"
  // engineType="client" => engine-free client (WASM query compiler, no native
  // Rust .node). Required on win32/arm64 where the x64 engine can't load.
  // Queries run through the node:sqlite driver adapter (see src/lib/db.ts).
  engineType = "client"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// ─── Users & auth ───────────────────────────────────────────────────────────

enum UserTier {
  SUPER_ADMIN
  ADMIN
  MEMBER
}

model User {
  id             Int      @id @default(autoincrement())
  uid            String?  @unique
  name           String
  nameAr         String? // Arabic display name (shown in the Arabic UI; falls back to `name`)
  fullName       String? // official full name (for documents); `name` is the display name
  fullNameAr     String? // Arabic official full name
  username       String? // optional login handle (login with username OR email); uniqueness enforced in code
  email          String   @unique
  primaryPhone   String?
  secondaryPhone String?
  yeldnPhone     String?
  passwordHash String
  tier         String   @default("MEMBER") // UserTier as string for SQLite portability
  locale       String   @default("en")
  themeKey     String?  // personal theme override (null = use app default)
  colorMode    String   @default("system") // light | dark | system
  active       Boolean  @default(true)
  avatarUrl    String?
  tokenVersion Int      @default(0) // bumped on password change → invalidates all existing session tokens
  failedLogins Int      @default(0) // consecutive failed login attempts (reset on success)
  lockedUntil  DateTime? // account temporarily locked after too many failed logins
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  archivedAt   DateTime?

  roles         UserRole[]
  teamMembers   TeamMember[]
  modulePerms   UserModulePermission[]
  resetTokens   PasswordResetToken[]
  pushSubscriptions PushSubscription[]
  pricingCalculations PricingCalculation[]
  expenseTransactions ExpenseTransaction[] @relation("ExpenseCreatedBy")
  employee            Employee?
}

model PasswordResetToken {
  id        Int      @id @default(autoincrement())
  userId    Int
  tokenHash String   @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

// A browser push subscription (one per device/browser per user). The Web Push
// endpoint is globally unique; p256dh + auth are the client's encryption keys.
model PushSubscription {
  id        Int      @id @default(autoincrement())
  userId    Int
  endpoint  String   @unique
  p256dh    String
  auth      String
  ua        String? // user-agent string, for the user to recognize the device
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

// Admin-composed notification broadcast to selected users — shown in the in-app
// inbox (per-recipient read state) and also web-pushed to subscribed devices.
model NotificationMessage {
  id           Int      @id @default(autoincrement())
  title        String
  body         String
  link         String? // app path opened on click
  imageAssetId String? // optional attached image (asset id)
  type         String   @default("info") // info | warning | success
  senderId     Int?
  createdAt    DateTime @default(now())

  recipients NotificationRecipient[]
}

model NotificationRecipient {
  id        Int                 @id @default(autoincrement())
  messageId Int
  message   NotificationMessage @relation(fields: [messageId], references: [id], onDelete: Cascade)
  userId    Int
  readAt    DateTime?

  @@unique([messageId, userId])
  @@index([userId])
}

// ─── Teams ──────────────────────────────────────────────────────────────────

model Team {
  id        Int      @id @default(autoincrement())
  key       String   @unique // sales, xoonx, purchasing, logistics, operations, couriers, development
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  members TeamMember[]
  roles   TeamRole[]
}

model TeamMember {
  id     Int  @id @default(autoincrement())
  teamId Int
  userId Int
  team   Team @relation(fields: [teamId], references: [id], onDelete: Cascade)
  user   User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([teamId, userId])
}

// ─── Roles & permissions ──────────────────────────────────────────────────────

model Role {
  id          Int      @id @default(autoincrement())
  key         String   @unique
  name        String
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  permissions RolePermission[]
  userRoles   UserRole[]
  teamRoles   TeamRole[]
}

model Permission {
  id    Int    @id @default(autoincrement())
  key   String @unique // e.g. "pricing.manage", "user_access.manage"
  label String

  roles RolePermission[]
}

model RolePermission {
  id           Int        @id @default(autoincrement())
  roleId       Int
  permissionId Int
  role         Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@unique([roleId, permissionId])
}

model UserRole {
  id     Int  @id @default(autoincrement())
  userId Int
  roleId Int
  user   User @relation(fields: [userId], references: [id], onDelete: Cascade)
  role   Role @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@unique([userId, roleId])
}

model TeamRole {
  id     Int  @id @default(autoincrement())
  teamId Int
  roleId Int
  team   Team @relation(fields: [teamId], references: [id], onDelete: Cascade)
  role   Role @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@unique([teamId, roleId])
}

// ─── Per-user, per-module access level ────────────────────────────────────────
// Level: NONE | VIEW | OPERATE | MANAGE (stored as string for SQLite portability).
// Permissions are purely per-user (teams do not auto-grant).

model UserModulePermission {
  id         Int    @id @default(autoincrement())
  userId     Int
  moduleKey  String
  level      String @default("NONE")
  user       User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, moduleKey])
  @@index([userId])
}

// ─── Module registry ──────────────────────────────────────────────────────────

model Module {
  id        Int     @id @default(autoincrement())
  key       String  @unique
  route     String
  section   String  // "main" | "admin"
  sortOrder Int     @default(0)
  enabled   Boolean @default(true)
}

// ─── Platform settings (single row) ───────────────────────────────────────────

model PlatformSettings {
  id          Int      @id @default(1)
  appName     String   @default("YeldnIN")
  brandColor  String   @default("37 99 235") // legacy/unused (theme drives --brand)
  themeKey    String   @default("default") // app-wide default theme
  logoUrl     String?  // light-mode logo (asset key)
  darkLogoUrl String?  // dark-mode logo (asset key)
  faviconUrl  String?  // favicon (asset key)
  version     String   @default("0.1.0") // app version label (admin-editable; seed no longer clobbers it)
  versionShowMobile  Boolean @default(false) // show the version badge on mobile?
  versionShowDesktop Boolean @default(true)  // show the version badge on desktop?
  copyrightEn String? // footer copyright note (English)
  copyrightAr String? // footer copyright note (Arabic)
  updatedAt   DateTime @updatedAt
}

// Uploaded files (branding, and later Pricing photos). Served via /api/asset/[id].
model Asset {
  id        String   @id @default(cuid())
  filename  String // stored filename on disk under /uploads
  mimeType  String
  size      Int
  createdAt DateTime @default(now())
}

// ─── Pricing module ───────────────────────────────────────────────────────────

model Supplier {
  id           Int       @id @default(autoincrement())
  name         String
  availableUSA Boolean   @default(false)
  availableUK  Boolean   @default(false)
  availableEU  Boolean   @default(false)
  contact      String?
  active       Boolean   @default(true)
  slaClass     String?   // delivery SLA class: STANDARD (30d) | FAST (20d); null = unset
  archivedAt   DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  products  Product[]
  purchases Purchase[]
}

// Managed country list for trips, hubs, and purchases (admin-editable). The
// pricing calculator's import regions (USA/UK/EU + supplier availability) are a
// separate concept and are NOT driven by this table.
model Country {
  id         Int       @id @default(autoincrement())
  name       String    @unique
  enabled    Boolean   @default(true)
  sortOrder  Int       @default(0)
  archivedAt DateTime?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
}

// Daily-cached FX rates for handling-fee conversion to EGP (live, best-effort).
// One row per foreign currency; `rate` is 1 unit of `currency` in EGP.
model FxRateCache {
  currency  String   @id // USD | GBP | EUR
  rate      Float
  fetchedAt DateTime
}

// Admin-managed notification routing. One row per event (overrides the
// code-defined defaults in notify-logic). Recipients = admins (notifyAdmins)
// + operators of moduleKeys + the order creator (notifyOrderCreator, where the
// event has an order context). statuses (CSV) applies to unit.milestone only.
model NotificationRule {
  event              String   @id // unit.milestone | items.flagged | issue.opened | trip.approval | sla.alert
  enabled            Boolean  @default(true)
  notifyAdmins       Boolean  @default(false)
  notifyOrderCreator Boolean  @default(false)
  moduleKeys         String   @default("") // CSV of module keys
  statuses           String   @default("") // CSV item statuses (unit.milestone)
  updatedById        Int?
  updatedAt          DateTime @updatedAt
}

// ─── CS Quality module (sales-rep evaluation scorecards) ──────────────────────

// Admin-editable type lists, scoped: CALL → Normal/Orders/Problems;
// PERIODICAL → Attitude/Effort/Time. Both editable.
model CsEvalType {
  id         Int       @id @default(autoincrement())
  scope      String // CALL | PERIODICAL
  name       String
  nameAr     String? // Arabic name (Arabic UI; falls back to `name`)
  sortOrder  Int       @default(0)
  weight     Int       @default(0) // CALL types: % weight within the Calls block of the overall average
  archivedAt DateTime?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  questions CsQuestion[]

  @@index([scope])
}

// Per-employee maximum monthly bonus (EGP) — earned in full at the top bonus tier.
model CsRepBonus {
  id        Int      @id @default(autoincrement())
  userId    Int      @unique // the evaluated sales rep
  maxBonus  Float    @default(0) // EGP at 100%+ of the bonus scale
  updatedAt DateTime @updatedAt
}

// Bonus tiers: ascending overall-average thresholds → % of the employee's max bonus.
model CsBonusTier {
  id        Int   @id @default(autoincrement())
  fromPct   Float // overall-average threshold (inclusive)
  bonusPct  Float // % of the max bonus (may exceed 100)
  sortOrder Int   @default(0)
}

// A weighted scorecard question. Soft-deleted (archivedAt) so past evaluations stay intact.
model CsQuestion {
  id          Int        @id @default(autoincrement())
  title       String     @default("")
  titleAr     String? // Arabic title (Arabic UI; falls back to `title`)
  criteria    String // the question body
  criteriaAr  String? // Arabic question body
  tags        String? // optional, comma-separated descriptive tags
  tagsAr      String? // Arabic tags (comma-separated)
  weight      Int        @default(1) // 1..10
  scope       String // CALL | PERFORMANCE
  typeId      Int
  type        CsEvalType @relation(fields: [typeId], references: [id])
  active      Boolean    @default(true)
  sortOrder   Int        @default(0)
  archivedAt  DateTime?
  createdById Int?
  createdAt   DateTime   @default(now())
  updatedById Int?
  updatedAt   DateTime   @updatedAt

  @@index([scope])
}

// Singleton JSON: per-scope answer-value maps (level → value).
model CsConfig {
  id        Int      @id @default(1)
  config    String   @default("{}")
  updatedAt DateTime @updatedAt
}

// One evaluation of a sales rep. User refs are plain ids (resolved separately),
// matching the rest of the schema. typeName/criteria are snapshotted on answers
// so later edits/soft-deletes don't rewrite history.
model CsEvaluation {
  id              Int       @id @default(autoincrement())
  uid             String?   @unique // CSE<YY><MM><seq3>
  subjectUserId   Int // the evaluated sales rep
  evaluatorUserId Int
  scope           String // CALL | PERFORMANCE
  typeName        String? // call type snapshot (null for performance)
  callDate        DateTime? // Call evals: the date of the call (drives analytics month)
  channel         String? // Call evals: contact channel key (WHATSAPP|PHONE|FACEBOOK|INSTAGRAM)
  contact         String? // Call evals: customer name / phone (free text)
  status          String    @default("PENDING") // PENDING | APPROVED | REJECTED
  total           Float     @default(0) // Σ weighted
  normalized      Float     @default(0) // % of best possible
  approvedById    Int?
  approvedAt      DateTime?
  rejectedNote    String?
  archivedAt      DateTime? // soft-delete
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  answers CsEvaluationAnswer[]
  photos  CsEvaluationPhoto[]

  @@index([subjectUserId])
  @@index([status])
}

model CsEvaluationAnswer {
  id           Int          @id @default(autoincrement())
  evaluationId Int
  evaluation   CsEvaluation @relation(fields: [evaluationId], references: [id], onDelete: Cascade)
  questionId   Int
  title        String   @default("") // snapshot
  titleAr      String? // Arabic snapshot
  criteria     String // snapshot (question body)
  criteriaAr   String? // Arabic snapshot
  typeName     String? // snapshot question type
  typeNameAr   String? // Arabic snapshot
  weight       Int // snapshot
  level        String // CATASTROPHE | BAD | GOOD | PERFECT | OUTSTANDING
  value        Float // snapshot value for the level
  weighted     Float // value * weight
  note         String?
}

model CsEvaluationPhoto {
  id           Int          @id @default(autoincrement())
  evaluationId Int
  evaluation   CsEvaluation @relation(fields: [evaluationId], references: [id], onDelete: Cascade)
  assetId      String
}

// ─── Supply chain: master data ────────────────────────────────────────────────

// Product catalog. scope: EGV | XOONX | PERSONAL.
// type: SUPPLEMENT | DEVICE | INJECTION | HEAVY_SUPPLEMENT | XOONX.
model Product {
  id                Int       @id @default(autoincrement())
  uid               String?   @unique // PRD<YY><MM><seq3>
  name              String
  sku               String?
  scope             String
  type              String
  originRegion      String?   // USA | UK | EU — gates the Default Supplier choices
  defaultSupplierId Int?
  defaultSupplier   Supplier? @relation(fields: [defaultSupplierId], references: [id])
  weightG           Float?
  purchasePrice     Float?
  sellingPrice      Float?
  size              String?
  grade             String?
  url               String?
  notes             String?
  isMaleSupport     Boolean   @default(false)
  active            Boolean   @default(true)
  archivedAt        DateTime?
  createdById       Int?
  createdAt         DateTime  @default(now())
  updatedById       Int?
  updatedAt         DateTime  @updatedAt

  photos       ProductPhoto[]
  items        Item[]
  requestLines RequestLine[]

  @@index([scope])
  @@index([type])
}

model ProductPhoto {
  id        Int      @id @default(autoincrement())
  productId Int
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  assetId   String
  createdAt DateTime @default(now())

  @@index([productId])
}

// Customer (Sales). contactChannel: WHATSAPP | PHONE | DIRECT | FACEBOOK | INSTAGRAM.
model Customer {
  id             Int       @id @default(autoincrement())
  uid            String?   @unique // CUS<YY><MM><seq3>
  name           String
  scope          String    @default("EGV") // EGV | XOONX (hard boundary, like requests/products)
  contactChannel String    @default("WHATSAPP")
  contactNumber  String?
  notes          String?
  active         Boolean   @default(true)
  archivedAt     DateTime?
  createdById    Int?
  createdAt      DateTime  @default(now())
  updatedById    Int?
  updatedAt      DateTime  @updatedAt

  requests Request[]

  @@index([scope])
}

// Traveler (Logistics). allowedProductTypes is a CSV of ProductType keys.
model Traveler {
  id                  Int       @id @default(autoincrement())
  uid                 String?   @unique // TRV<YY><MM><seq3>
  name                String
  contact             String?
  notes               String?
  referenceTravelerId Int?
  reference           Traveler? @relation("TravelerRef", fields: [referenceTravelerId], references: [id])
  referredBy          Traveler[] @relation("TravelerRef")
  active              Boolean   @default(true)
  blacklisted         Boolean   @default(false)
  staticAddress       Boolean   @default(false)
  carriesMaleSupport  Boolean   @default(false)
  allowedProductTypes String    @default("")
  archivedAt          DateTime?
  createdById         Int?
  createdAt           DateTime  @default(now())
  updatedById         Int?
  updatedAt           DateTime  @updatedAt

  photos TravelerPhoto[]
  trips  Trip[]
}

model TravelerPhoto {
  id         Int      @id @default(autoincrement())
  travelerId Int
  traveler   Traveler @relation(fields: [travelerId], references: [id], onDelete: Cascade)
  assetId    String
  createdAt  DateTime @default(now())

  @@index([travelerId])
}

// Trip (Logistics) — a traveler's journey carrying items to Egypt. Inherits
// allowed types / male-support / notes from the traveler. Its contents are the
// Items pointing at it (containerType=TRIP). status drives the late lifecycle.
model Trip {
  id                  Int       @id @default(autoincrement())
  uid                 String?   @unique // TRP<YY><MM><seq3>
  travelerId          Int
  traveler            Traveler  @relation(fields: [travelerId], references: [id])
  country             String
  maxWeight           Float?
  dealPricePerKg      Float?
  lastReceivingDate   DateTime?
  deliveryDateInEgypt DateTime?
  allowedProductTypes String    @default("")
  maleSupport         Boolean   @default(false)
  notes               String?
  handlingFee         Float?
  handlingFeeCurrency String?
  status              String    @default("NEW")
  archivedAt          DateTime?
  createdById         Int?
  createdAt           DateTime  @default(now())
  updatedById         Int?
  updatedAt           DateTime  @updatedAt

  shipments Shipment[]
  marks     TripMark[]

  @@index([status])
}

// 3-team review on a picked-up trip. One mark per (trip, team). Each team sees
// only its own mark; admins see all and approve (OK→convert) or Hold.
model TripMark {
  id        Int       @id @default(autoincrement())
  tripId    Int
  trip      Trip      @relation(fields: [tripId], references: [id], onDelete: Cascade)
  team      String // PURCHASING | LOGISTICS | OPERATIONS
  status    String // OK | ISSUE
  note      String?
  byUserId  Int?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  photos TripMarkPhoto[]

  @@unique([tripId, team])
  @@index([tripId])
}

model TripMarkPhoto {
  id        Int      @id @default(autoincrement())
  markId    Int
  mark      TripMark @relation(fields: [markId], references: [id], onDelete: Cascade)
  assetId   String
  createdAt DateTime @default(now())

  @@index([markId])
}

// Issues & Compensations. Issues open from a trip-review ISSUE mark, a
// lost/damaged event, or manually. Compensations: supplier → replacement
// (a Purchase @ price 0), traveler → money (EGP).
model Issue {
  id          Int       @id @default(autoincrement())
  uid         String?   @unique // ISS<YY><MM><seq3>
  title       String
  note        String?
  status      String    @default("OPEN") // OPEN | SOLVED
  outcome     String?   // closure reason for exception issues: RECOVERED | COMPENSATED | NO_COMPENSATION
  scope       String?
  sourceType  String? // TRIP_MARK | MANUAL | EXCEPTION
  sourceId    Int?
  createdById Int?
  createdAt   DateTime  @default(now())
  updatedById Int?
  updatedAt   DateTime  @updatedAt
  resolvedAt  DateTime?

  photos        IssuePhoto[]
  items         IssueItem[]
  compensations Compensation[]

  @@index([status])
}

model IssuePhoto {
  id        Int      @id @default(autoincrement())
  issueId   Int
  issue     Issue    @relation(fields: [issueId], references: [id], onDelete: Cascade)
  assetId   String
  createdAt DateTime @default(now())

  @@index([issueId])
}

model IssueItem {
  id      Int    @id @default(autoincrement())
  issueId Int
  issue   Issue  @relation(fields: [issueId], references: [id], onDelete: Cascade)
  itemId  Int
  label   String // snapshot (product name + uid) for display

  @@index([issueId])
}

model Compensation {
  id          Int      @id @default(autoincrement())
  issueId     Int
  issue       Issue    @relation(fields: [issueId], references: [id], onDelete: Cascade)
  type        String // PRODUCT | MONEY
  amountEgp   Float? // for MONEY
  note        String?
  createdById Int?
  createdAt   DateTime @default(now())

  @@index([issueId])
}

// Shipment (Operations) — created by splitting a picked-up Trip by scope/size.
// Its contents are the Items pointing at it (containerType=SHIPMENT). Scope
// drives who can see it (EGV→EGV+admin, XOONX→XOONX+admin, PERSONAL→admin).
// Courier (Couriers) — a delivery partner. Referenced by Patches (and later
// the customer-delivery Orders). Master data.
model Courier {
  id          Int       @id @default(autoincrement())
  uid         String?   @unique // CUR<YY><MM><seq3>
  name        String
  contact     String?
  active      Boolean   @default(true)
  archivedAt  DateTime?
  createdById Int?
  createdAt   DateTime  @default(now())
  updatedById Int?
  updatedAt   DateTime  @updatedAt
}

model Shipment {
  id          Int       @id @default(autoincrement())
  uid         String?   @unique // SHP<YY><MM><seq3>
  scope       String
  tripId      Int?
  trip        Trip?     @relation(fields: [tripId], references: [id])
  status      String    @default("OFFICE") // OFFICE | PHOTOS_SENT | WEBSITE
  archivedAt  DateTime?
  createdById Int?
  createdAt   DateTime  @default(now())
  updatedById Int?
  updatedAt   DateTime  @updatedAt

  @@index([scope])
  @@index([status])
}

// Hub (Logistics) — an abroad receiving point with inventory. country: USA | UK | EU.
model Hub {
  id          Int       @id @default(autoincrement())
  uid         String?   @unique // HUB<YY><MM><seq3>
  name        String
  country     String
  notes       String?
  active      Boolean   @default(true)
  archivedAt  DateTime?
  createdById Int?
  createdAt   DateTime  @default(now())
  updatedById Int?
  updatedAt   DateTime  @updatedAt

  photos HubPhoto[]
}

model HubPhoto {
  id        Int      @id @default(autoincrement())
  hubId     Int
  hub       Hub      @relation(fields: [hubId], references: [id], onDelete: Cascade)
  assetId   String
  createdAt DateTime @default(now())

  @@index([hubId])
}

// ─── Supply chain: the tracked item + its movement engine ─────────────────────

// One physical unit, tracked from Request to Customer. `status` is the canonical
// ItemStatus (lib/workflow/workflow-logic). Current location is polymorphic
// (containerType + containerId); exceptionFlag moves it to a shared pool while
// remembering its source container. Timer fields drive the auto-advance worker.
model Item {
  id                  Int       @id @default(autoincrement())
  uid                 String?   @unique // ITM<YY><MM><seq3>
  productId           Int
  product             Product   @relation(fields: [productId], references: [id])
  scope               String // EGV | XOONX | PERSONAL (denormalized for fast filtering)
  status              String    @default("REQUESTED")
  containerType       String? // REQUEST | PURCHASE | PATCH | TRANSFER | TRIP | HUB | TRAVELER | SHIPMENT | ORDER
  containerId         Int?
  country             String? // physical country (set on receipt; carried into traveler holding) — drives same-country transfers
  requestId           Int? // origin request (anchor for pool returns)
  exceptionFlag       String? // LOST | DAMAGED | ERRANT | DELAYED
  sourceContainerType String?
  sourceContainerId   Int?
  exceptionNote       String?   // optional reason captured when flagged
  exceptionAt         DateTime? // when the current flag was set (triage ordering)
  exceptionById       Int?      // who flagged it
  exceptionIssueId    Int?      // the auto-opened Issue (LOST/DAMAGED/ERRANT), to close on "found"
  isSpecialOrder      Boolean   @default(false)
  isGift              Boolean   @default(false) // free item received from a supplier (no value)
  slaAlertedStatus    String?   // last special-order SLA status we alerted on (RISK|DELAYED); dedup
  sellingPrice        Float?
  purchasePrice       Float?
  purchaseCurrency    String? // XOONX: USD|GBP|EUR for the purchase cost (EGP when null)
  receivedAt          DateTime? // set when status → HUB; drives the timers
  promisedDeliveryAt  DateTime? // special order: delivery guarantee (createdAt + grace), frozen at creation
  transitAt           DateTime? // scheduled auto-advance → TRANSIT
  globalShippingAt    DateTime? // scheduled auto-advance → GLOBAL_SHIPPING
  notes               String?
  createdById         Int?
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  events ItemEvent[]

  @@index([status])
  @@index([scope])
  @@index([containerType, containerId])
  @@index([requestId])
  @@index([exceptionFlag])
}

model ItemEvent {
  id            Int      @id @default(autoincrement())
  itemId        Int
  item          Item     @relation(fields: [itemId], references: [id], onDelete: Cascade)
  fromStatus    String?
  toStatus      String
  containerType String?
  containerId   Int?
  action        String?
  byUserId      Int?
  createdAt     DateTime @default(now())

  @@index([itemId])
}

// ─── Supply chain: Request (Sales/XOONX) — the first container ─────────────────
// type: SPECIAL_ORDER | OUT_OF_STOCK | RESTOCK | OPTIONAL. Submitting a request
// spawns one Item per unit (count) at REQUESTED.
model Request {
  id          Int       @id @default(autoincrement())
  uid         String?   @unique // REQ<YY><MM><seq3>
  type        String
  scope       String
  customerId  Int?
  customer    Customer? @relation(fields: [customerId], references: [id])
  notes       String?
  deposit     Float?    // special order: agreed deposit (EGP), per request
  deliveredAt DateTime? // XOONX: set when the order is delivered → revenue recognised that month
  archivedAt  DateTime?
  createdById Int?
  createdAt   DateTime  @default(now())
  updatedById Int?
  updatedAt   DateTime  @updatedAt

  lines  RequestLine[]
  photos RequestPhoto[]

  @@index([scope])
  @@index([type])
}

model RequestLine {
  id            Int      @id @default(autoincrement())
  requestId     Int
  request       Request  @relation(fields: [requestId], references: [id], onDelete: Cascade)
  productId     Int
  product       Product  @relation(fields: [productId], references: [id])
  count         Int      @default(1)
  sellingPrice  Float?
  purchasePrice Float?
  purchaseCurrency String? // XOONX: USD|GBP|EUR (EGP when null)
  notes         String?

  @@index([requestId])
}

model RequestPhoto {
  id        Int      @id @default(autoincrement())
  requestId Int
  request   Request  @relation(fields: [requestId], references: [id], onDelete: Cascade)
  assetId   String
  createdAt DateTime @default(now())

  @@index([requestId])
}

// Purchase (Purchasing) — drawn from the pending-request pool. Its contents are
// the Items pointing at it (containerType=PURCHASE). destinationType: HUB (TRIP
// once the Trip container exists). status mirrors the container flow.
model Purchase {
  id              Int       @id @default(autoincrement())
  uid             String?   @unique // PUR<YY><MM><seq3>
  scope           String
  country         String
  supplierId      Int?
  supplier        Supplier? @relation(fields: [supplierId], references: [id])
  supplierName    String?
  purchasePrice   Float?
  destinationType String    @default("HUB")
  destinationId   Int?
  destinationName String?
  notes           String?
  handlingFee         Float?
  handlingFeeCurrency String?
  status          String    @default("NEW") // NEW | DISPATCHED | DELIVERED | RECEIVED
  archivedAt      DateTime?
  createdById     Int?
  createdAt       DateTime  @default(now())
  updatedById     Int?
  updatedAt       DateTime  @updatedAt

  patches Patch[]

  @@index([scope])
  @@index([status])
}

// Patch (Logistics) — a shipment from Supplier to a destination (Hub for now;
// Trip once that exists). Created from a Purchase; carries the chosen ORDERED
// items SHIPPED → DELIVERED → HUB(received). Its contents are the Items pointing
// at it (containerType=PATCH).
model Patch {
  id              Int       @id @default(autoincrement())
  uid             String?   @unique // PAT<YY><MM><seq3>
  purchaseId      Int?
  purchase        Purchase? @relation(fields: [purchaseId], references: [id])
  scope           String
  country         String
  supplierName    String?
  destinationType String    @default("HUB")
  destinationId   Int?
  destinationName String?
  tracking        String?
  courierId       Int? // → Courier (the partner); courier holds the name snapshot
  courier         String? // courier name snapshot (or free text)
  status          String    @default("DISPATCHED") // DISPATCHED | DELIVERED | RECEIVED
  dispatchedAt    DateTime  @default(now())
  deliveredAt     DateTime?
  receivedAt      DateTime?
  notes           String?
  handlingFee         Float?
  handlingFeeCurrency String?
  archivedAt      DateTime?
  createdById     Int?
  createdAt       DateTime  @default(now())
  updatedById     Int?
  updatedAt       DateTime  @updatedAt

  photos PatchPhoto[]

  @@index([scope])
  @@index([status])
}

model PatchPhoto {
  id        Int      @id @default(autoincrement())
  patchId   Int
  patch     Patch    @relation(fields: [patchId], references: [id], onDelete: Cascade)
  assetId   String
  createdAt DateTime @default(now())

  @@index([patchId])
}

// Transfer (Logistics) — moves received stock between two destinations
// (Hub / Trip / Traveler-holding), same country. Multi-step like a Patch:
// NEW → LEFT_ORIGIN → DELIVERED → RECEIVED; at RECEIVED its items re-receive at
// the destination (status HUB + transit timers reset). Endpoints are polymorphic
// (type ∈ HUB|TRIP|TRAVELER). Its contents are the Items pointing at it
// (containerType=TRANSFER).
model Transfer {
  id           Int       @id @default(autoincrement())
  uid          String?   @unique // TRF<YY><MM><seq3>
  country      String
  fromType     String // HUB | TRIP | TRAVELER
  fromId       Int
  fromName     String?
  toType       String // HUB | TRIP | TRAVELER
  toId         Int
  toName       String?
  tracking     String?
  courierId    Int? // → Courier (the partner)
  courier      String? // courier name snapshot (or free text)
  status       String    @default("NEW") // NEW | LEFT_ORIGIN | DELIVERED | RECEIVED
  leftOriginAt DateTime?
  deliveredAt  DateTime?
  receivedAt   DateTime?
  notes        String?
  archivedAt   DateTime?
  createdById  Int?
  createdAt    DateTime  @default(now())
  updatedById  Int?
  updatedAt    DateTime  @updatedAt

  photos TransferPhoto[]

  @@index([status])
  @@index([fromType, fromId])
  @@index([toType, toId])
}

model TransferPhoto {
  id         Int      @id @default(autoincrement())
  transferId Int
  transfer   Transfer @relation(fields: [transferId], references: [id], onDelete: Cascade)
  assetId    String
  createdAt  DateTime @default(now())

  @@index([transferId])
}

model PricingCalculation {
  id           Int       @id @default(autoincrement())
  section      String // SUPPLEMENT | DEVICE
  productName  String?
  importedFrom String
  supplierId   Int?
  supplierName String?
  price        Float
  inputJson    String // JSON snapshot of inputs
  configJson   String // JSON snapshot of the config used (so history is reproducible)
  notes        String?
  userId       Int
  user         User      @relation(fields: [userId], references: [id])
  createdAt    DateTime  @default(now())
  deletedAt    DateTime? // soft delete: hidden from the owner, visible to admin
  deletedById  Int?
  photos       PricingPhoto[]

  @@index([section])
  @@index([userId])
}

model PricingPhoto {
  id            Int                @id @default(autoincrement())
  calculationId Int
  assetId       String
  calculation   PricingCalculation @relation(fields: [calculationId], references: [id], onDelete: Cascade)
  createdAt     DateTime           @default(now())

  @@index([calculationId])
}

model PricingSettings {
  id        Int      @id @default(1)
  config    String // JSON of PricingConfig
  updatedAt DateTime @updatedAt
}

// Singleton holding admin overrides to the per-level capability defaults.
// `overrides` is JSON: { [moduleKey]: { [capabilityKey]: Level } }. Missing
// entries fall back to the in-code defaults (see lib/auth/capabilities.ts).
model AccessPolicy {
  id        Int      @id @default(1)
  overrides String   @default("{}")
  updatedAt DateTime @updatedAt
}

// Singleton holding admin overrides to the supply-chain Status Map (decision
// "A"): status label renames (EN/AR), per-view carry-forward sets, and timer
// ranges. The stages/transitions themselves are fixed in code
// (lib/workflow/workflow-logic.ts); only this presentation layer is editable.
// `overrides` is JSON shaped as WorkflowOverrides.
model WorkflowConfig {
  id        Int      @id @default(1)
  overrides String   @default("{}")
  updatedAt DateTime @updatedAt
}

// Singleton holding the special-order delivery SLA config: grace days per source
// class (injection / standard / fast retailer) for each scope (EGV, XOONX) and
// the risk window. `config` is JSON shaped as SlaSettings (lib/sla/sla-logic).
model SlaConfig {
  id        Int      @id @default(1)
  config    String   @default("{}")
  updatedAt DateTime @updatedAt
}

// ─── Expenses module (Operations cash + sales reconciliation) ─────────────────

model ExpenseCategory {
  id        Int       @id @default(autoincrement())
  name      String
  nameAr    String? // Arabic name (admin-entered; shown in the Arabic UI, falls back to `name`)
  type      String // "EXPENSE" | "TRANSFER"
  enabled   Boolean   @default(true)
  sortOrder Int       @default(0)
  deletedAt DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  transactions ExpenseTransaction[]
}

model ExpenseTransaction {
  id                   Int              @id @default(autoincrement())
  amount               Float
  categoryId           Int?
  category             ExpenseCategory? @relation(fields: [categoryId], references: [id])
  categoryNameSnapshot String
  categoryTypeSnapshot String // "EXPENSE" | "TRANSFER"
  note                 String?
  accruingDate         DateTime? // user-entered execution date (تاريخ التنفيذ); UTC-midnight, date-only. Null on legacy rows → falls back to createdAt.
  createdById          Int
  createdBy            User             @relation("ExpenseCreatedBy", fields: [createdById], references: [id])
  createdAt            DateTime         @default(now()) // registering timestamp (system-stamped, date + time)
  updatedById          Int?
  updatedAt            DateTime         @updatedAt

  // Admin/manager review flag for clarification or discussion; operate users see it but can't set it.
  flag        String? // null | "RED" | "YELLOW"
  flagNote    String?
  flaggedById Int?
  flaggedAt   DateTime?

  attachments ExpenseAttachment[]

  @@index([categoryTypeSnapshot])
  @@index([createdAt])
  @@index([createdById])
  @@index([flag])
}

// Links an expense transaction to an uploaded Asset (reuses the shared upload primitive).
model ExpenseAttachment {
  id            Int                @id @default(autoincrement())
  transactionId Int
  transaction   ExpenseTransaction @relation(fields: [transactionId], references: [id], onDelete: Cascade)
  assetId       String
  uploadedById  Int?
  uploadedAt    DateTime           @default(now())

  @@index([transactionId])
}

model ExpenseAccount {
  id        Int       @id @default(autoincrement())
  name      String
  enabled   Boolean   @default(true)
  sortOrder Int       @default(0)
  deletedAt DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  collectionLines MonthlyBankCollectionLine[]
}

model MonthlySalesReport {
  id                          Int      @id @default(autoincrement())
  year                        Int
  month                       Int
  totalSales                  Float
  cashToStaff                 Float    @default(0)
  cashToAramex                Float    @default(0)
  cashToSmsa                  Float    @default(0)
  bankTransferAndMobileWallet Float    @default(0)
  creditCard                  Float    @default(0)
  note                        String?
  createdById                 Int
  createdAt                   DateTime @default(now())
  updatedById                 Int?
  updatedAt                   DateTime @updatedAt

  @@unique([year, month])
}

model MonthlyBankCollectionReport {
  id          Int      @id @default(autoincrement())
  year        Int
  month       Int
  note        String?
  createdById Int
  createdAt   DateTime @default(now())
  updatedById Int?
  updatedAt   DateTime @updatedAt

  lines MonthlyBankCollectionLine[]

  @@unique([year, month])
}

model MonthlyBankCollectionLine {
  id                  Int                         @id @default(autoincrement())
  reportId            Int
  report              MonthlyBankCollectionReport @relation(fields: [reportId], references: [id], onDelete: Cascade)
  accountId           Int?
  account             ExpenseAccount?             @relation(fields: [accountId], references: [id])
  accountNameSnapshot String
  amount              Float
}

model MonthlyReconciliationNote {
  id          Int      @id @default(autoincrement())
  year        Int
  month       Int
  note        String?
  createdById Int
  createdAt   DateTime @default(now())
  updatedById Int?
  updatedAt   DateTime @updatedAt

  @@unique([year, month])
}

// ─── XOONX finance (petty-cash expenses, FX, staff profit-share, month close) ──
// Ported from the prior app. EGP money; user ids are plain (resolved by name).

model XoonxExpenseCategory {
  id        Int       @id @default(autoincrement())
  name      String
  enabled   Boolean   @default(true)
  sortOrder Int       @default(0)
  deletedAt DateTime? // soft-delete; categories with records are never hard-deleted

  expenses XoonxExpense[]
}

// A local (Egypt) expense paid by XOONX staff from the shared petty cash.
model XoonxExpense {
  id                   Int      @id @default(autoincrement())
  date                 DateTime @default(now())
  categoryId           Int?
  categoryNameSnapshot String
  amount               Float // EGP
  note                 String?
  requestId            Int? // optional link to a XOONX request
  tripId               Int? // optional link to a trip
  createdById          Int
  createdAt            DateTime @default(now())
  updatedById          Int?
  updatedAt            DateTime @updatedAt

  category XoonxExpenseCategory? @relation(fields: [categoryId], references: [id])

  @@index([date])
  @@index([categoryId])
}

// Admin-set monthly FX rate (1 <currency> = rate EGP) for converting foreign costs.
model XoonxFxRate {
  id          Int      @id @default(autoincrement())
  month       String // "YYYY-MM"
  currency    String // USD | GBP | EUR
  rate        Float
  updatedById Int?
  updatedAt   DateTime @updatedAt

  @@unique([month, currency])
}

// A closed/published month: locks edits, snapshots the report, records the petty refill.
model XoonxMonthClose {
  id           Int      @id @default(autoincrement())
  month        String   @unique // "YYYY-MM"
  closedAt     DateTime @default(now())
  closedById   Int
  snapshotJson String
  pettyRefill  Float    @default(0)
}

// Admin-set share of the staff profit pool (the 25%) per XOONX staff user.
model XoonxStaffShare {
  id       Int   @id @default(autoincrement())
  userId   Int   @unique
  sharePct Float @default(0) // percent of the staff (25%) pool
}

// ─── Content pages (admin-authored static pages; public at /p/[slug]) ─────────

model ContentPage {
  id           Int      @id @default(autoincrement())
  slug         String   @unique // url-safe: [a-z0-9-]
  titleEn      String
  titleAr      String   @default("")
  bodyEn       String   @default("") // Markdown
  bodyAr       String   @default("") // Markdown
  visibility   String   @default("PUBLIC") // "PUBLIC" | "INTERNAL"
  published    Boolean  @default(false)
  showInFooter Boolean  @default(true)
  showInMenu   Boolean  @default(true)
  sortOrder    Int      @default(0)
  createdById  Int
  createdAt    DateTime @default(now())
  updatedById  Int?
  updatedAt    DateTime @updatedAt

  @@index([published])
}

// ─── Audit log (cross-module activity trail) ──────────────────────────────────

model AuditLog {
  id         Int      @id @default(autoincrement())
  userId     Int? // plain id (resolved by name on display)
  moduleKey  String   @default("") // which module's settings/data was edited
  action     String
  entityType String
  entityId   String
  meta       String? // JSON
  createdAt  DateTime @default(now())

  @@index([moduleKey])
  @@index([createdAt])
}

// ─── Human Resources ──────────────────────────────────────────────────────────
// One Employee per User (strict 1:1, userId unique). Display name/full name come
// from the linked User; the Employee holds HR-specific fields. lineManagerId is
// the employee's direct manager (another Employee). EmployeeEvent is the
// per-employee life-events log (auto changes + manual notes).
model Employee {
  id                Int       @id @default(autoincrement())
  uid               String?   @unique // EMP<YY><MM><seq3>
  userId            Int       @unique
  user              User      @relation(fields: [userId], references: [id])
  nationalIdNumber  String?
  nationalIdExpiry  DateTime?
  gradDegree        String?
  gradUniversity    String?
  gradFaculty       String?
  birthDate         DateTime?
  hiringDate        DateTime?
  annualAllowance   Int? // per-employee yearly leave override; null = HrConfig default
  urgentAllowance   Int?
  lineManagerId     Int?
  lineManager       Employee?  @relation("EmployeeManager", fields: [lineManagerId], references: [id])
  reports           Employee[] @relation("EmployeeManager")
  notes             String?
  archivedAt        DateTime?
  createdById       Int?
  createdAt         DateTime  @default(now())
  updatedById       Int?
  updatedAt         DateTime  @updatedAt

  photos      EmployeePhoto[]
  events      EmployeeEvent[]
  salaryLines SalaryStructureLine[]
  payslips    Payslip[]

  @@index([lineManagerId])
}

model EmployeePhoto {
  id         Int      @id @default(autoincrement())
  employeeId Int
  employee   Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  kind       String // ID_FRONT | ID_BACK | GRAD_CERT | BIRTH_CERT | OTHER
  assetId    String
  label      String?
  createdAt  DateTime @default(now())

  @@index([employeeId])
}

// Per-employee life-events log: auto (CREATED | PROFILE_EDIT | MANAGER_CHANGED)
// + manual NOTE. Aggregated company-wide for an HR audit feed.
model EmployeeEvent {
  id         Int      @id @default(autoincrement())
  employeeId Int
  employee   Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  type       String // CREATED | PROFILE_EDIT | MANAGER_CHANGED | NOTE
  message    String
  byUserId   Int?
  createdAt  DateTime @default(now())

  photos EmployeeEventPhoto[]

  @@index([employeeId])
  @@index([createdAt])
}

model EmployeeEventPhoto {
  id        Int           @id @default(autoincrement())
  eventId   Int
  event     EmployeeEvent @relation(fields: [eventId], references: [id], onDelete: Cascade)
  assetId   String
  createdAt DateTime      @default(now())

  @@index([eventId])
}

// ─── HR Phase 2 — Attendance & Leaves ─────────────────────────────────────────
// Singleton config: company-default yearly allowances + the weekly-off weekday(s)
// (CSV of JS getDay() numbers, 0=Sun..6=Sat; Egypt default Friday=5).
model HrConfig {
  id            Int      @id @default(autoincrement())
  annualDefault Int      @default(21)
  urgentDefault Int      @default(7)
  weeklyOffDays String   @default("5")
  // Vacation→duty mapping (DayType codes): which duty results from working each
  // kind of non-working day. Seeded, admin-editable.
  dutyEidDays     String @default("ED")
  dutyEidVacation String @default("D")
  dutyVacation    String @default("VD")
  dutyWeekend     String @default("D")
  updatedById   Int?
  updatedAt     DateTime @updatedAt
}

// A leave request: planned time off that deducts the type's yearly balance.
model LeaveRequest {
  id          Int       @id @default(autoincrement())
  uid         String?   @unique // LV<YY><MM><seq3>
  employeeId  Int
  type        String // ANNUAL | URGENT
  startDate   DateTime
  endDate     DateTime
  days        Int // working days consumed (skips weekends + holidays)
  reason      String?
  status      String    @default("PENDING") // PENDING | APPROVED | DECLINED
  decidedById Int?
  decidedAt   DateTime?
  decidedNote String?
  createdById Int?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([employeeId])
  @@index([status])
}

// An unplanned absence marked by a manager/admin. Consumes an Urgent day if the
// employee still has Urgent balance; otherwise it's over-limit (Phase-4 penalty).
model Absence {
  id              Int      @id @default(autoincrement())
  employeeId      Int
  date            DateTime
  note            String?
  coveredByUrgent Boolean  @default(false)
  markedById      Int?
  createdAt       DateTime @default(now())

  @@unique([employeeId, date])
  @@index([employeeId])
}

// Official vacation (dated). type: EID_DAYS | EID_VACATION | VACATION. Weekly
// off-days live in HrConfig.weeklyOffDays. Per-team bonus-per-day for working it
// lives in HolidayBonus (used by Payroll, Phase 4).
model Holiday {
  id          Int       @id @default(autoincrement())
  uid         String?   @unique // HOL<YY><MM><seq3>
  title       String
  titleAr     String?
  type        String // EID_DAYS | EID_VACATION | VACATION
  startDate   DateTime
  endDate     DateTime
  notes       String?
  archivedAt  DateTime?
  createdById Int?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  bonuses HolidayBonus[]

  @@index([startDate])
}

model HolidayBonus {
  id           Int      @id @default(autoincrement())
  holidayId    Int
  holiday      Holiday  @relation(fields: [holidayId], references: [id], onDelete: Cascade)
  teamId       Int
  amountPerDay Float
  createdAt    DateTime @default(now())

  @@unique([holidayId, teamId])
  @@index([holidayId])
}

// ─── HR Phase 2.5 — Day Types & Salary Components (configurable catalogs) ──────
// SalaryComponent: a building block of pay. kind EARNING (base/allowances, sum in)
// | BONUS (sum in, earned) | PENALTY (deduct). `valuation` says how a structure
// line's figure is interpreted (Phase 3 stores the figure; Phase 4 realizes it):
//   FIXED_MONTHLY  constant monthly amount (Basic, fixed allowances)        [EGP]
//   FIXED_EVENT    fixed amount when earned/charged (target bonus, penalty) [EGP]
//   PER_DAY_FIXED  fixed amount per qualifying day (working a vacation/Eid)  [EGP]
//   DAYS_OF_BASIC  N × (basic ÷ 26) — bonus expressed in days of basic     [days]
//   DAYS_OF_TOTAL  N × (total ÷ working days) — penalty in days of total   [days]
// `defaultAmount` is the company-wide figure used when an employee has no override.
model SalaryComponent {
  id            Int       @id @default(autoincrement())
  code          String    @unique
  name          String
  nameAr        String?
  kind          String // EARNING | BONUS | PENALTY
  valuation     String    @default("FIXED_EVENT") // see header
  defaultAmount Float? // company-wide default figure (EGP or days per valuation)
  notes         String?
  system        Boolean   @default(false)
  archivedAt    DateTime?
  sortOrder     Int       @default(0)
  createdById   Int?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  lines SalaryStructureLine[]
}

// ─── HR Phase 3 — Salary structures & raises ──────────────────────────────────
// One line of an employee's salary structure: an applicable component + its
// current figure. `amount` is EGP for fixed/per-day valuations, or a day-count
// for DAYS_OF_* valuations (resolved to money in Payroll P4). Every change is
// journalled in SalaryChange; the line always reflects the latest applied change.
model SalaryStructureLine {
  id          Int             @id @default(autoincrement())
  employeeId  Int
  employee    Employee        @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  componentId Int
  component   SalaryComponent @relation(fields: [componentId], references: [id])
  amount      Float           @default(0)
  active      Boolean         @default(true)
  note        String?
  createdById Int?
  createdAt   DateTime        @default(now())
  updatedById Int?
  updatedAt   DateTime        @updatedAt

  changes SalaryChange[]

  @@unique([employeeId, componentId])
  @@index([employeeId])
}

// Effective-dated history of every figure change on a structure line. changeType
// SET (initial/explicit absolute) | FIXED (signed EGP delta) | PERCENT (% of old).
// `delta` carries the entered value per type; old→new are the resulting amounts.
// `batchId` groups the lines touched by one bulk raise.
model SalaryChange {
  id            Int                 @id @default(autoincrement())
  lineId        Int
  line          SalaryStructureLine @relation(fields: [lineId], references: [id], onDelete: Cascade)
  changeType    String // SET | FIXED | PERCENT
  delta         Float
  oldAmount     Float
  newAmount     Float
  effectiveDate DateTime
  reason        String?
  batchId       String?
  byUserId      Int?
  createdAt     DateTime            @default(now())

  @@index([lineId])
  @@index([effectiveDate])
}

// ─── HR Phase 4 — Payroll run (computed, saved payslips) ──────────────────────
// One employee's payslip for a pay-month M. Per the doc's pay-window (day 24–31):
// basic + allowances are for the current month M, attendance-derived bonuses come
// from the previous month M−1, absences/penalties from the current month M. A slip
// is DRAFT (recomputable) then LOCKED (immutable history). Header fields are the
// frozen roll-up; PayslipLine holds the breakdown. net is floored at zero.
model Payslip {
  id              Int       @id @default(autoincrement())
  uid             String?   @unique // PS<YY><MM><seq3>
  employeeId      Int
  employee        Employee  @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  year            Int
  month           Int // pay-month M (1–12)
  status          String    @default("DRAFT") // DRAFT | LOCKED
  basic           Float     @default(0) // basic salary (for day-of-basic reference)
  earningsTotal   Float     @default(0)
  bonusTotal      Float     @default(0)
  penaltyTotal    Float     @default(0)
  gross           Float     @default(0) // earnings + bonuses (before penalties)
  net             Float     @default(0) // max(0, gross − penalties)
  workingDays     Int       @default(0) // company working days in M (day-of-total divisor)
  dayOfBasic      Float     @default(0) // basic ÷ 26
  dayOfTotal      Float     @default(0) // gross ÷ workingDays
  absentOverLimit Int       @default(0) // over-limit absences in M (penalised)
  notes           String?
  generatedById   Int?
  lockedById      Int?
  lockedAt        DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  lines PayslipLine[]

  @@unique([employeeId, year, month])
  @@index([employeeId])
}

// A single breakdown line. `source` distinguishes auto-derived lines (regenerated
// on recompute) from manual ones (TARGET toggle, ADHOC event — preserved). For
// day-valued lines, qty/rate/valuation are stored so `amount` can be recomputed.
model PayslipLine {
  id          Int      @id @default(autoincrement())
  payslipId   Int
  payslip     Payslip  @relation(fields: [payslipId], references: [id], onDelete: Cascade)
  kind        String // EARNING | BONUS | PENALTY
  source      String // STRUCTURE | DUTY | TARGET | ABSENCE | ADHOC
  componentId Int?
  label       String
  valuation   String? // for recompute of day-valued lines
  qty         Float? // duty-day count, or number of days for days-of-X
  rate        Float? // per-day or fixed figure
  amount      Float    @default(0) // resolved magnitude (sign implied by kind)
  detail      String? // human-readable computation note
  createdById Int?
  createdAt   DateTime @default(now())

  @@index([payslipId])
}

// DayType: a configurable classification of a day. dayClass LEAVE (employee off)
// or DUTY (present on a special day). Each may grant a bonus and/or a penalty
// (SalaryComponent ids; plain Int, resolved in the service).
model DayType {
  id                 Int       @id @default(autoincrement())
  code               String    @unique
  name               String
  nameAr             String?
  dayClass           String // LEAVE | DUTY
  bonusComponentId   Int?
  penaltyComponentId Int?
  system             Boolean   @default(false)
  archivedAt         DateTime?
  sortOrder          Int       @default(0)
  createdById        Int?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt
}

// A duty day: an employee worked a non-working day (Eid/vacation/weekend) or was
// in training — classified by a DayType (ED/D/VD/L). Manual, per employee+date.
model DutyDay {
  id         Int      @id @default(autoincrement())
  employeeId Int
  date       DateTime
  dayTypeId  Int
  note       String?
  markedById Int?
  createdAt  DateTime @default(now())

  @@unique([employeeId, date])
  @@index([employeeId])
}

// ─── UID counter (human-readable codes: <PREFIX><YY><MM><seq3>) ────────────────

model Counter {
  id     Int    @id @default(autoincrement())
  prefix String
  period String // "YYMM"
  value  Int    @default(0)

  @@unique([prefix, period])
}
